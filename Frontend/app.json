{
  "expo": {
    "name": "SafeNepalApp",
    "slug": "SafeNepalApp",
    "version": "1.0.0",
    "scheme": "safenepalapp",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E1621"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.esprihya.safenepalapp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs your location to send SOS alerts during disasters."
      }
    },
    "android": {
      "package": "com.esprihya.safenepalapp",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDummyKeyForDevelopmentOnly123456789"
        }
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow SafeNepalApp to use your location for emergency reporting."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "permissions": [
              "INTERNET",
              "ACCESS_NETWORK_STATE",
              "ACCESS_COARSE_LOCATION",
              "ACCESS_FINE_LOCATION",
              "SEND_SMS"
            ]
          }
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "17cb65ce-f6dd-44f7-900d-87a0ac153076"
      }
    }
  }
}
