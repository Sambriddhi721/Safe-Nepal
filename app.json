{
  "expo": {
    "name": "SafeNepalApp",
    "slug": "SafeNepalApp",
    "version": "1.0.0",
    "scheme": "safenepalapp",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.esprihya.safenepalapp",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SafeNepalApp uses your location to show nearby help.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SafeNepalApp needs background location for emergency tracking.",
        "NSPhotoLibraryUsageDescription": "Safe Nepal needs access to your photos to let you update your profile picture."
      }
    },
    "android": {
      "package": "com.esprihya.safenepalapp",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "INTERNET",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "react-native-maps",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "17cb65ce-f6dd-44f7-900d-87a0ac153076"
      }
    }
  }
}