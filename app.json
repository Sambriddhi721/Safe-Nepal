{
  "expo": {
    "name": "SafeNepalApp",
    "slug": "SafeNepalApp",
    "version": "1.0.0",
    "scheme": "safenepalapp",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.esprihya.safenepalapp",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SafeNepalApp uses your location to show nearby help.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SafeNepalApp needs background location for emergency tracking."
      }
    },
    "android": {
      "package": "com.esprihya.safenepalapp",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "INTERNET",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "react-native-maps"
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "17cb65ce-f6dd-44f7-900d-87a0ac153076"
      }
    }
  }
}
